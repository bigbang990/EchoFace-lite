# Copy to .env and adjust. Never commit .env.

# API
APP_NAME=EcoFace Lite
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Paths (relative to project root or absolute)
DATA_DIR=data
UPLOADS_DIR=data/uploads
SNAPSHOTS_DIR=data/snapshots
VIDEOS_DIR=data/videos
LOG_DIR=logs

# Database — SQLite for local dev; use postgresql+asyncpg://... later
DATABASE_URL=sqlite+aiosqlite:///./data/ecoface_lite.db

# AI / InsightFace
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_CTX_ID=-1
DETECTION_CONFIDENCE_THRESHOLD=0.5
MATCH_CONFIDENCE_THRESHOLD=0.55

# Tracking / temporal perception
TRACKING_CONFIRM_FRAMES=2
TRACKING_STABLE_FRAMES=15
TRACKING_MIN_RECOGNITION_QUALITY=0.40
TRACKING_EMBEDDING_COOLDOWN_FRAMES=12
TRACKING_SOFT_MATCH_MARGIN=0.08
TRACKING_MIN_SOFT_THRESHOLD=0.38
TRACKING_GLOBAL_MEMORY_TTL_FRAMES=90
TRACKING_REID_MIN_SIMILARITY=0.38
TRACKING_TEMPORAL_LOCK_MIN_AGREEMENT=4
DETECTOR_INTERVAL_MIN_FRAMES=4
DETECTOR_INTERVAL_MAX_FRAMES=16
DETECTOR_INTERVAL_STABLE_FRAMES=12
MOTION_MAX_FRAME_DISPLACEMENT_PX=120

# Processing
VIDEO_FRAME_SKIP=1
MAX_IMAGE_MB=10
